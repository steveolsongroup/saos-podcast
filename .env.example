# Copy to .env and fill in. Never commit .env (it's gitignored).

# --- Notion ---
# Reuse your existing Notion internal integration token (the one already used by
# scaling-agent-os-web). The two databases below MUST be shared with that integration.
NOTION_TOKEN=

# Created by the integration build (Podcast Command Center page):
NOTION_PODCAST_DB=157a60a48fc34f2a832784d24644c831
NOTION_PODCAST_STATS_DB=101e953af1d5427d9a9009e1c550c9c1

# --- Captivate ---
# Captivate dashboard -> your name (top right) -> My Account -> API Key
CAPTIVATE_USER_ID=
CAPTIVATE_API_KEY=
# Run `npm run show-id` after setting the two above to discover this:
CAPTIVATE_SHOW_ID=

# Optional: timezone label (defaults to UTC); cosmetic only.
# TIMEZONE=America/New_York
